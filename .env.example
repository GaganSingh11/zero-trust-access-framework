# Keycloak Admin Console credentials
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# OIDC connection settings (used by FastAPI)
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=zero-trust-demo
KEYCLOAK_CLIENT_ID=zt-platform-api
KEYCLOAK_CLIENT_SECRET=zt-secret-change-me

# Application settings
LOG_LEVEL=INFO
LOG_FILE=logs/audit.log
